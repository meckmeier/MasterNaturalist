#don't commit your .env file as it stores your development environment variables.

.env

# =====================
# Python / Virtualenv
# =====================
venv/                     # your virtual environment
__pycache__/              # compiled Python files
*.py[cod]                 # .pyc, .pyo, .pyd
*.pyo
*$py.class

# Optional: Ignore Django staticfiles output
staticfiles/

# =====================
# Django specific
# =====================
*.log                     # log files
*.sqlite3                 # local SQLite DBs
media/                     # user-uploaded files
staticfiles/               # collected static files

# Ignore compiled Python inside migrations only
**/migrations/__pycache__/

# Ignore local settings if you use them for secrets
local_settings.py

# =====================
# IDE / Editor
# =====================
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# =====================
# OS
# =====================
.DS_Store
Thumbs.db

# =====================
# Jupyter / Data files
# =====================
.ipynb_checkpoints/
*.csv
*.xlsx
*.h5
*.hdf5-e "venv/\nstaticfiles/\n__pycache__/\n*.py[cod]" 
